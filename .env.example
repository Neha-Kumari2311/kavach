# ══════════════════════════════════════════════════════════════
# Kavach - Environment Variables
# Copy this file to .env.local and fill in your values
# ══════════════════════════════════════════════════════════════

# ── MongoDB ──
# Local: mongodb://localhost:27017/kavach
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/kavach
MONGODB_URI=mongodb://localhost:27017/kavach

# ── NextAuth ──
# NEXTAUTH_URL must match your deployment URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# ── Application ──
NODE_ENV=development

# ── AI Backend (Python gesture detection server) ──
AI_BACKEND_URL=http://127.0.0.1:5000/detect

# ── Vapi Voice AI (optional - voice assistant) ──
# Get keys from https://dashboard.vapi.ai
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=
VAPI_PRIVATE_API_KEY=

# ── AWS SES & SNS (optional - email/SMS alerts via voice assistant) ──
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL_ADDRESS=

# ══════════════════════════════════════════════════════════════
# DEPLOYMENT NOTES:
# - For Vercel: Add all vars in Project Settings → Environment Variables
# - For Docker: Pass via docker-compose.yml or --env-file flag
# - NEXTAUTH_URL must be your production URL (e.g., https://kavach.yourdomain.com)
# - NEXTAUTH_SECRET must be unique and strong in production
# ══════════════════════════════════════════════════════════════
